<?xml version="1.0"?>
<launch>
  <arg name="model" default="$(find r2d2)/urdf/r2d2_sensor.urdf"/>

  <param name="robot_description"
         command="$(find xacro)/xacro $(arg model)" />

  <node name="robot_state_publisher"
        pkg="robot_state_publisher"
        type="robot_state_publisher" />

  <node name="rviz"
        pkg="rviz"
        type="rviz" />
</launch>
